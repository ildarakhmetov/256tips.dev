<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="theme-color" content="#FF4133">
  <title>{{ title }}</title>
  <link rel="canonical" href="{{ url |> url(true) }}">
  {{ if og_image_width }}<meta property="og:image:width" content="{{ og_image_width }}">{{ /if }}
  {{ if og_image_height }}<meta property="og:image:height" content="{{ og_image_height }}">{{ /if }}
  {{ if og_image_alt }}<meta property="og:image:alt" content="{{ og_image_alt }}">{{ /if }}
  <link rel="alternate" type="application/rss+xml" title="256 Tips for Developers" href="/feed.xml">
  <link rel="icon" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'%3E%3Crect width='100' height='100' fill='%23F3EDE1'/%3E%3Crect x='0' y='82' width='100' height='18' fill='%23FF4133'/%3E%3Ctext x='50' y='66' text-anchor='middle' font-family='Georgia, serif' font-size='44' font-weight='900' fill='%230D0D0D'%3E256%3C/text%3E%3C/svg%3E">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght,SOFT,WONK@0,9..144,400..900,0..100,0..1;1,9..144,400..900,0..100,0..1&family=Instrument+Sans:ital,wght@0,400..700;1,400..700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/styles.css">
  <!-- Cloudflare Web Analytics beacon inserted in the deploy task -->
</head>
<body class="bg-paper font-sans antialiased">
  <nav class="border-b-4 border-black bg-white">
    <div class="max-w-6xl mx-auto px-4 md:px-8 py-4 flex justify-between items-center gap-6">
      <a href="/" class="font-display font-black text-xl md:text-2xl leading-none hover:text-riso-red transition-colors" style="font-variation-settings: 'SOFT' 80, 'opsz' 48, 'WONK' 1;">256 Tips <span class="text-riso-red">for Developers</span></a>
      <div class="flex items-baseline gap-6">
        <a href="/" class="font-semibold hover:text-riso-red transition-colors">All Tips</a>
        <a href="https://ildarakhmetov.com/" class="font-semibold hover:text-riso-red transition-colors">About</a>
      </div>
    </div>
  </nav>

  <main class="max-w-6xl mx-auto p-4 md:p-8 prose prose-lg prose-headings:font-black prose-h1:text-4xl prose-h2:text-3xl prose-h3:text-2xl prose-h4:text-xl prose-ul:list-disc prose-ul:ml-6">
    {{ content }}
  </main>

  <footer class="border-t-4 border-black bg-white mt-16">
    <div class="max-w-6xl mx-auto px-4 md:px-8 py-6 flex flex-col md:flex-row md:items-baseline gap-4 md:gap-8">
      <span class="font-semibold text-sm">by <a href="https://ildarakhmetov.com/" class="underline hover:text-riso-red transition-colors">Ildar Akhmetov</a></span>
      <div class="md:ml-auto text-xs opacity-60 flex flex-col md:items-end gap-1">
        <div>© 2026 Ildar Akhmetov · Tips CC BY-NC-ND 4.0</div>
        <div>Built with Deno + Lume · <a href="https://github.com/ildarakhmetov/256tips.dev" class="hover:text-riso-red transition-colors">Source</a> · <a href="/feed.xml" class="hover:text-riso-red transition-colors">RSS</a></div>
      </div>
    </div>
  </footer>
</body>
</html>
